# FrankenPHP / Caddy config for TableFlip behind a reverse proxy.
#
# Listens on :8080 in HTTP only — Traefik / nginx / Caddy upstream is
# expected to terminate TLS, set X-Forwarded-* headers and proxy to us.
# The trusted_proxies setting in config/trustedproxy.php should match the
# proxy network.

{
    # Disable Caddy admin (avoid leaking it through Traefik).
    admin off

    # Caddy global server options.
    auto_https off

    # FrankenPHP runtime config — keep php-fpm semantics by default. To use
    # worker mode for better perf, set FRANKENPHP_NUM_THREADS env var and
    # uncomment the worker block below.
    frankenphp {
        # worker /app/public/index.php
    }
}

:8080 {
    root * /app/public

    encode zstd br gzip

    # Honour the X-Forwarded-* headers so Laravel sees the right host/scheme.
    request_header >X-Real-IP {client_ip}

    # PHP via FrankenPHP.
    php_server {
        try_files {path} {path}/ /index.php?{query}
        # Disable file_server's default directory-browsing for safety.
        browse off
    }

    # Long-lived caches for the built assets.
    @assets path /build/* /fonts/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Sensible logging — JSON to stdout so Docker/Dokploy can collect it.
    log {
        output stdout
        format json
    }
}
