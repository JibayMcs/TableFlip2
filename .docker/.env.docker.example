# TableFlip — production environment template.
#
# Copy this file to .env.docker (or to your Dokploy "Environment" tab) and
# fill the placeholders. Variables marked REQUIRED must be set, the rest
# have safe defaults.

# --- Application -----------------------------------------------------------

# REQUIRED — generate ONCE locally with `php artisan key:generate --show`
# and keep it forever. Changing it invalidates every encrypted DB password
# stored in the `database_connections` table.
APP_KEY=base64:CHANGE_ME_TO_A_REAL_KEY

# REQUIRED — the public URL Traefik points at TableFlip (used for absolute
# links + signed export download URLs).
APP_URL=https://tableflip.example.com

APP_TIMEZONE=UTC

# --- Storage database (BYODB) ----------------------------------------------
#
# This is where TableFlip stores its own data : users, saved connections,
# audit log, etc. NOT the databases users will browse — those are added at
# runtime via the Connections UI.
#
# We support mysql / mariadb / pgsql / sqlsrv / sqlite here. For
# self-hosted setups, MariaDB is the easiest path.

DB_CONNECTION=mysql
DB_HOST=mariadb.example.com
DB_PORT=3306
DB_DATABASE=tableflip
DB_USERNAME=tableflip
DB_PASSWORD=CHANGE_ME

# --- Redis -----------------------------------------------------------------

# Optional but recommended — set if you want to lock the bundled Redis
# down. Leave empty for no password (compose runs Redis on a private net).
REDIS_PASSWORD=

# --- Exports ---------------------------------------------------------------

TABLEFLIP_EXPORTS_RETENTION_DAYS=7

# --- Mail (optional) -------------------------------------------------------

MAIL_MAILER=log
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=user
# MAIL_PASSWORD=secret
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME=TableFlip
