# TableFlip — production environment template.
#
# Copy this file to .env.docker (or paste in Dokploy's Environment tab)
# and fill the placeholders. Variables marked REQUIRED must be set, the
# rest have safe defaults baked into the container.

# --- Application -----------------------------------------------------------

# REQUIRED — generate ONCE locally with `php artisan key:generate --show`
# and keep it forever. Changing it invalidates every encrypted DB password
# stored in the `database_connections` table.
APP_KEY=base64:CHANGE_ME_TO_A_REAL_KEY

# REQUIRED — the public URL Traefik points at TableFlip (used for absolute
# links + signed export download URLs).
APP_URL=https://tableflip.example.com

APP_TIMEZONE=UTC

# --- Storage database ------------------------------------------------------
#
# Where TableFlip stores ITS OWN data : users, saved connections, audit log,
# exports metadata. NOT the databases you'll browse — those are added at
# runtime via the Connections UI / direct login.
#
# SQLite default = zero external dependency, one file on the storage
# volume. Perfect for self-hosted single-instance setups. Hot paths
# (queue / cache / sessions) live in Redis (see below) so SQLite stays
# cool and free of write contention.
#
# Swap for MariaDB / Postgres if you need multi-instance / HA — see
# "Upgrading the storage DB" in .docker/README.md.

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/storage/app/tableflip.sqlite

# --- Queue / cache / sessions (Redis) -------------------------------------
#
# Redis runs in the compose stack and handles every high-volume write so
# we never hammer the SQLite file. Sessions in Redis means logins survive
# container restarts (data is persisted via Redis appendonly).

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Direct DB login (PMA-style) ------------------------------------------
#
# When TableFlip is mainly used as a PMA replacement, disable the Breeze
# (account) tab and lock the direct-login form to your usual server.

# AUTH_BREEZE_ENABLED=false
# AUTH_DIRECT_DB_ENABLED=true
# TABLEFLIP_ALLOWED_DB_HOSTS=mariadb.example.com
# TABLEFLIP_ALLOWED_DB_DRIVERS=mysql
# TABLEFLIP_ALLOWED_DB_NAMES=mydb
# TABLEFLIP_REQUIRE_DB_NAME=true

# --- Exports ---------------------------------------------------------------

TABLEFLIP_EXPORTS_RETENTION_DAYS=7

# --- Mail (optional) -------------------------------------------------------

MAIL_MAILER=log
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=user
# MAIL_PASSWORD=secret
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME=TableFlip
