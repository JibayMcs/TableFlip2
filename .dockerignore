# Keep build context small + avoid leaking dev artefacts in the image.

.git
.github
.gitignore
.gitattributes
.editorconfig

# IDE / editor
.idea
.vscode
.fleet

# Dev artefacts
node_modules
vendor
public/build
public/storage
# Entire storage tree is created on the named volume by entrypoint.
# Shipping anything here would force Docker to pre-populate the volume
# from image content and conflict with Dokploy's volume mgmt.
storage
bootstrap/cache/*.php

# Local env / secrets
.env
.env.*
!.docker/.env.docker.example

# Original code (reference only, not part of the runtime)
docs/original_code

# Tests, dev docs
tests
phpunit.xml
phpstan.neon
phpstan.dist.neon
psalm.xml
.phpunit.cache

# Misc
*.log
.DS_Store
