{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowJs": true,
        "noEmit": true,
        "isolatedModules": true,
        "resolveJsonModule": true
    },
    "include": ["resources/js/**/*"]
}
